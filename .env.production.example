NODE_ENV=production
PORT=3000

# Frontend origin(s) allowed to call API with cookies.
# For single-service deploy, set both to your public app URL.
APP_ORIGIN=https://your-app.onrender.com
APP_ORIGINS=https://your-app.onrender.com
TRUST_PROXY=1

DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

JWT_SECRET=replace-with-64-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-different-64-char-random-string
JWT_REFRESH_EXPIRES_IN=7d

# Keep empty for same-origin deployment (recommended)
VITE_API_URL=

# Configure one email provider
EMAIL_FROM=noreply@yourdomain.com
# EMAIL_RESEND_API_KEY=re_xxx
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=pass

# Optional TURN server for better WebRTC reliability
# TURN_URL=turn:your-turn-server:3478
# TURN_USER=your-turn-user
# TURN_PASS=your-turn-pass
