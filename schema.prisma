generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String        @id @default(uuid())
  email                 String        @unique
  name                  String
  passwordHash          String
  emailVerified          Boolean       @default(false)
  emailVerificationToken String?       // 32-byte hex token for email verification link
  passwordResetToken     String?       // 32-byte hex token for password reset link
  passwordResetExpires   DateTime?     // Reset link expiry (30 min from creation)
  failedLoginAttempts    Int           @default(0)
  lockedUntil            DateTime?
  avatarId              Int           @default(0)
  preferences           Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  hostedMeetings        Meeting[]     @relation("MeetingHost")
  participations        Participant[]
  refreshTokens         RefreshToken[]

  @@map("users")
}

model Meeting {
  id               String        @id @default(uuid())
  title            String
  status           MeetingStatus @default(SCHEDULED)
  scheduledStartAt DateTime
  scheduledEndAt   DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  hostId           String
  host             User          @relation("MeetingHost", fields: [hostId], references: [id], onDelete: Restrict)
  participants     Participant[]

  @@index([hostId])
  @@index([status, scheduledStartAt])
  @@map("meetings")
}

model Participant {
  id             String          @id @default(uuid())
  userId         String
  meetingId      String
  role           ParticipantRole @default(GUEST)
  joinedAt       DateTime?
  leftAt         DateTime?
  createdAt      DateTime        @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting        Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([userId, meetingId])
  @@index([meetingId])
  @@index([userId])
  @@map("participants")
}

enum MeetingStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

// ── Refresh token storage (rotation + revocation) ──
model RefreshToken {
  id           String   @id @default(uuid())
  tokenHash    String   @unique  // SHA-256 hash of the actual token
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedBy   String?  // ID of the token that replaced this one (rotation chain)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

enum ParticipantRole {
  HOST
  CO_HOST
  GUEST
  INTERPRETER
}

model Message {
  id        String   @id @default(uuid())
  meetingId String
  senderId  String
  senderName String
  text      String
  createdAt DateTime @default(now())

  @@index([meetingId])
  @@map("messages")
}

