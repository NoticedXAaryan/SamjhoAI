NODE_ENV=development
PORT=3000
APP_ORIGIN=http://localhost:5173

# Neon PostgreSQL — use Supavisor pooler URL for production
# For dev: direct connection string from Neon dashboard
# For prod: pooler connection string (see Neon dashboard → Connection pooler)
# ACTION REQUIRED (free): Enable Supavisor in Neon dashboard for connection pooling
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-different-64-char-random-string
JWT_REFRESH_EXPIRES_IN=7d

# Email — set one (Resend or SMTP). In dev, links are logged to console.
# ACTION REQUIRED (free): Sign up at resend.com, generate API key for real emails
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_RESEND_API_KEY=re_xxx...
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=pass

# TURN server for WebRTC (improves connectivity behind corporate NATs)
# ACTION REQUIRED (free-ish): Deploy coturn on a small VPS or render/fly.io
# TURN_URL=turn:your-turn-server:3478
# TURN_USER=your-turn-username
# TURN_PASS=your-turn-password
