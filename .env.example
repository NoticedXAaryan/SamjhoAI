NODE_ENV="development"
PORT="3000"

# Frontend origin — used for CORS
APP_ORIGIN="http://localhost:3000"

# ─── Database ───────────────────────────────────────────────────────────────
# Get this from Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-a-64-char-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-a-different-64-char-random-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Frontend (Vite) ────────────────────────────────────────────────────────
# Backend API URL — in production, set this to your Render.com URL
# In development this is unused (Vite proxies to the same server)
VITE_API_URL="http://localhost:3000"
